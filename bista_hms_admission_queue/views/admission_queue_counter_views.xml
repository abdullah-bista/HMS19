<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bista_admission_queue_counter_list" model="ir.ui.view">
        <field name="name">bista.admission.queue.counter.list</field>
        <field name="model">bista.admission.queue.counter</field>
        <field name="arch" type="xml">
            <list string="Admission Queue Counters" create="false" delete="false" edit="false">
                <field name="counter_date"/>
                <field name="ward_id"/>
                <field name="last_token_number" string="Tokens Issued"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_bista_admission_queue_counter_form" model="ir.ui.view">
        <field name="name">bista.admission.queue.counter.form</field>
        <field name="model">bista.admission.queue.counter</field>
        <field name="arch" type="xml">
            <form string="Admission Queue Counter">
                <sheet>
                    <group>
                        <field name="counter_date"/>
                        <field name="ward_id"/>
                        <field name="last_token_number" readonly="1"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bista_admission_queue_counter" model="ir.actions.act_window">
        <field name="name">Admission Queue Counters</field>
        <field name="res_model">bista.admission.queue.counter</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
