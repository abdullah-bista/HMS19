<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">

    <!-- Appointments: portal user sees only their own; perm_create=True for the new request flow -->
    <record id="hms_appointment_portal_rule" model="ir.rule">
      <field name="name">Portal Patient's Own Appointments</field>
      <field name="model_id" ref="acs_hms.model_hms_appointment"/>
      <field name="domain_force">
        [('patient_id.partner_id', '=', user.commercial_partner_id.id)]
      </field>
      <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="False"/>
      <field name="perm_create" eval="True"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Prescriptions: read-only -->
    <record id="hms_prescription_portal_rule" model="ir.rule">
      <field name="name">Portal Patient's Own Prescriptions</field>
      <field name="model_id" ref="acs_hms.model_prescription_order"/>
      <field name="domain_force">
        [('patient_id.partner_id', '=', user.commercial_partner_id.id)]
      </field>
      <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="False"/>
      <field name="perm_create" eval="False"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Treatments: read-only -->
    <record id="hms_treatment_portal_rule" model="ir.rule">
      <field name="name">Portal Patient's Own Treatments</field>
      <field name="model_id" ref="acs_hms.model_hms_treatment"/>
      <field name="domain_force">
        [('patient_id.partner_id', '=', user.commercial_partner_id.id)]
      </field>
      <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="False"/>
      <field name="perm_create" eval="False"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Evaluations: read-only -->
    <record id="hms_evaluation_portal_rule" model="ir.rule">
      <field name="name">Portal Patient's Own Evaluations</field>
      <field name="model_id" ref="acs_hms.model_acs_patient_evaluation"/>
      <field name="domain_force">
        [('patient_id.partner_id', '=', user.commercial_partner_id.id)]
      </field>
      <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="False"/>
      <field name="perm_create" eval="False"/>
      <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Prescription Lines: read-only (needed for medicine detail display) -->
    <record id="hms_prescription_line_portal_rule" model="ir.rule">
      <field name="name">Portal Patient's Own Prescription Lines</field>
      <field name="model_id" ref="acs_hms.model_prescription_line"/>
      <field name="domain_force">
        [('prescription_id.patient_id.partner_id', '=', user.commercial_partner_id.id)]
      </field>
      <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
      <field name="perm_read" eval="True"/>
      <field name="perm_write" eval="False"/>
      <field name="perm_create" eval="False"/>
      <field name="perm_unlink" eval="False"/>
    </record>

  </data>
</odoo>
