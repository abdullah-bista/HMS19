<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Multi-company record rule: users see only their company's queue records -->
        <record id="rule_bista_upcoming_queue_company" model="ir.rule">
            <field name="name">Upcoming Queue: Company</field>
            <field name="model_id" ref="model_bista_upcoming_patient_queue"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

    </data>
</odoo>
