<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Multi-company record rule: users can only see counters for their company -->
        <record id="rule_bista_queue_counter_company" model="ir.rule">
            <field name="name">Queue Counter: Company</field>
            <field name="model_id" ref="model_bista_queue_counter"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>
    </data>
</odoo>
