<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- My Patients: filtered by primary_physician_id linked to current user -->
    <record id="action_my_patients" model="ir.actions.act_window">
        <field name="name">My Patients</field>
        <field name="res_model">hms.patient</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('primary_physician_id.user_id', '=', uid)]</field>
        <field name="search_view_id" ref="acs_hms_base.view_patient_filter"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No patients found.</p>
            <p>Patients where you are set as the primary care doctor will appear here.</p>
        </field>
    </record>

</odoo>
