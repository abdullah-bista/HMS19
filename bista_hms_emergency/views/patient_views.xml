<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         PATIENT FORM EXTENSION — Emergency & Admission Smart Buttons
    ============================================================ -->

    <record id="view_patient_form_emergency_inherit" model="ir.ui.view">
        <field name="name">hms.patient.form.emergency.inherit</field>
        <field name="model">hms.patient</field>
        <field name="inherit_id" ref="acs_hms_base.view_patient_form"/>
        <field name="arch" type="xml">

            <!-- Smart Buttons -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_emergency_cases" type="object"
                    class="oe_stat_button" icon="fa-ambulance"
                    invisible="emergency_count == 0">
                    <div class="o_stat_info">
                        <field name="emergency_count" class="o_stat_value"/>
                        <span class="o_stat_text">ER Cases</span>
                    </div>
                </button>
                <button name="action_view_admissions" type="object"
                    class="oe_stat_button" icon="fa-hospital-o"
                    invisible="admission_count == 0">
                    <div class="o_stat_info">
                        <field name="admission_count" class="o_stat_value"/>
                        <span class="o_stat_text">Admissions</span>
                    </div>
                </button>
            </xpath>

            <!-- Current Admission / Emergency Banner -->
            <xpath expr="//div[@class='oe_title']" position="before">
                <!-- Emergency Banner -->
                <div class="alert alert-danger mb-0 rounded-0" role="alert"
                    invisible="not is_emergency">
                    <i class="fa fa-exclamation-triangle me-2"/>
                    <strong>ACTIVE EMERGENCY CASE</strong>
                    — Patient is currently in the Emergency Department.
                </div>
                <!-- Admission Banner -->
                <div class="alert alert-info mb-0 rounded-0" role="alert"
                    invisible="not is_admitted">
                    <i class="fa fa-hospital-o me-2"/>
                    <strong>CURRENTLY ADMITTED</strong>
                    — Ward: <field name="current_ward_id" nolabel="1" readonly="1"/>
                    | Bed: <field name="current_bed_id" nolabel="1" readonly="1"/>
                </div>
            </xpath>

        </field>
    </record>

</odoo>
