<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         BED VIEWS
    ============================================================ -->

    <record id="view_bed_form" model="ir.ui.view">
        <field name="name">hms.bed.form</field>
        <field name="model">hms.bed</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_reserve" string="Reserve" type="object"
                        invisible="state != 'available'" class="btn-primary"/>
                    <button name="action_mark_available" string="Mark Available" type="object"
                        invisible="state not in ('reserved', 'maintenance')"/>
                    <button name="action_mark_maintenance" string="Set Maintenance" type="object"
                        invisible="state in ('occupied', 'maintenance')"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="available,reserved,occupied,maintenance"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Bed Identifier (e.g. ICU-01-B1)"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Location">
                            <field name="room_id"/>
                            <field name="ward_id"/>
                        </group>
                        <group string="Properties">
                            <field name="bed_type"/>
                            <field name="daily_rate"/>
                            <field name="product_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_bed_list" model="ir.ui.view">
        <field name="name">hms.bed.list</field>
        <field name="model">hms.bed</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'available'"
                  decoration-danger="state == 'occupied'"
                  decoration-warning="state == 'maintenance'"
                  decoration-info="state == 'reserved'">
                <field name="name"/>
                <field name="ward_id"/>
                <field name="room_id"/>
                <field name="bed_type"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'available'"
                    decoration-danger="state == 'occupied'"
                    decoration-warning="state == 'maintenance'"
                    decoration-info="state == 'reserved'"/>
                <field name="daily_rate"/>
            </list>
        </field>
    </record>

    <record id="view_bed_kanban" model="ir.ui.view">
        <field name="name">hms.bed.kanban</field>
        <field name="model">hms.bed</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="state"/>
                <field name="ward_id"/>
                <field name="room_id"/>
                <field name="bed_type"/>
                <field name="daily_rate"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click
                            #{record.state.raw_value == 'available' ? 'border-success' :
                              record.state.raw_value == 'occupied' ? 'border-danger' :
                              record.state.raw_value == 'reserved' ? 'border-primary' : 'border-warning'}">
                            <div class="oe_kanban_content p-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span t-attf-class="badge rounded-pill
                                        #{record.state.raw_value == 'available' ? 'bg-success' :
                                          record.state.raw_value == 'occupied' ? 'bg-danger' :
                                          record.state.raw_value == 'reserved' ? 'bg-primary' : 'bg-warning'}">
                                        <field name="state"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_subtitle text-muted small">
                                    <i class="fa fa-map-marker"/> <field name="ward_id"/> — <field name="room_id"/>
                                </div>
                                <div class="mt-1 small">
                                    <i class="fa fa-tag"/> <field name="bed_type"/>
                                    <span t-if="record.daily_rate.raw_value" class="ms-2">
                                        <i class="fa fa-money"/> <field name="daily_rate"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_bed_search" model="ir.ui.view">
        <field name="name">hms.bed.search</field>
        <field name="model">hms.bed</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="ward_id"/>
                <field name="room_id"/>
                <filter string="Available" name="available" domain="[('state','=','available')]"/>
                <filter string="Occupied" name="occupied" domain="[('state','=','occupied')]"/>
                <filter string="Reserved" name="reserved" domain="[('state','=','reserved')]"/>
                <filter string="Under Maintenance" name="maintenance" domain="[('state','=','maintenance')]"/>
                <separator/>
                <filter string="ICU Beds" name="icu" domain="[('bed_type','=','icu')]"/>
                <group>
                    <filter string="Ward" name="group_ward" context="{'group_by': 'ward_id'}"/>
                    <filter string="Room" name="group_room" context="{'group_by': 'room_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Bed Type" name="group_type" context="{'group_by': 'bed_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bed" model="ir.actions.act_window">
        <field name="name">All Beds</field>
        <field name="res_model">hms.bed</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <record id="action_bed_kanban" model="ir.actions.act_window">
        <field name="name">Bed Availability Board</field>
        <field name="res_model">hms.bed</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_available': 1}</field>
    </record>

</odoo>
